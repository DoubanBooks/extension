{
  "manifest_version": 3,
  "name": "豆瓣图书-查二手书价格",
  "version": "1.0.9",
  "description": "在豆瓣图书页面显示二手书比价信息（孔夫子、多抓鱼、漫游鲸等）",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://book.douban.com/*",
    "https://search.kongfz.com/*",
    "https://api.taoshu.com/*",
    "https://apiv3.manyoujing.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://book.douban.com/subject/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
